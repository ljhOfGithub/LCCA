# Database
DATABASE_URL=postgresql+asyncpg://lcca_user:lcca_password@localhost:5432/lcca_exam
DATABASE_URL_SYNC=postgresql://lcca_user:lcca_password@localhost:5432/lcca_exam

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO/S3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lcca-artifacts

# S3 region (optional)
S3_REGION=us-east-1

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# Secrets (replace with secure values in production)
SECRET_KEY=replace-with-a-strong-secret
JWT_SECRET=replace-with-jwt-secret

# LLM / AI provider
# Example: OpenAI style key. Do NOT commit real keys to git.
LLM_API_KEY=sk-REPLACE_ME
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ASR (speech-to-text) service
ASR_API_KEY=replace-with-asr-key
ASR_API_URL=https://api.example.com/asr

# Frontend URL (for CORS / redirects)
FRONTEND_URL=http://localhost:3000

# Timeouts (seconds)
ATTEMPT_TIMEOUT_SECONDS=7200
SCORING_TIMEOUT_SECONDS=300